<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fillViewport="true"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 标题行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="健康周报"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_report_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#2A2A4E"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="--"
                android:textColor="#7C4DFF"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- 数据行 -->
        <TextView
            android:id="@+id/tv_data_water"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="2dp"
            android:text="--"
            android:textColor="#CCCCCC"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tv_data_sleep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="2dp"
            android:text="--"
            android:textColor="#CCCCCC"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tv_data_steps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="2dp"
            android:text="--"
            android:textColor="#CCCCCC"
            android:textSize="11sp" />

        <!-- 分隔 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="6dp"
            android:background="#333355" />

        <!-- AI 分析 -->
        <TextView
            android:id="@+id/tv_ai_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI 建议"
            android:textColor="#7C4DFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingBottom="2dp" />

        <ProgressBar
            android:id="@+id/pb_ai_loading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminateTint="#7C4DFF"
            android:visibility="gone"
            style="?android:attr/progressBarStyleHorizontal" />

        <TextView
            android:id="@+id/tv_ai_analysis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="2dp"
            android:text=""
            android:textColor="#AAAAAA"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btn_ai_refresh"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginTop="4dp"
            android:text="刷新分析"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:backgroundTint="#7C4DFF"
            android:minWidth="0dp"
            android:paddingHorizontal="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

    </LinearLayout>
</ScrollView>
