<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 水面波动背景 -->
    <com.example.yibei.ui.WaterWaveView
        android:id="@+id/water_wave"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 右上角提示文字（每次进入喝水页显示3秒后消失） -->
    <TextView
        android:id="@+id/tv_onboarding_tip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|top"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="68dp"
        android:text="点击右上角测试"
        android:textSize="13sp"
        android:textColor="#1A1A2E"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="@drawable/bg_onboarding_tip"
        android:elevation="4dp"
        android:visibility="gone" />

    <!-- 右上角收纳按钮 -->
    <ImageButton
        android:id="@+id/btn_menu"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="end|top"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_menu_more"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="功能菜单"
        android:tint="#546E7A" />

    <!-- 中间内容 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="40dp">

        <!-- 水量数字 -->
        <TextView
            android:id="@+id/tv_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="56sp"
            android:textColor="#1565C0"
            android:textStyle="bold"
            android:fontFamily="sans-serif-light" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ml"
            android:textSize="20sp"
            android:textColor="#1976D2"
            android:layout_marginTop="-4dp" />

        <!-- 进度 -->
        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="目标 2000ml  ·  0%"
            android:textSize="14sp"
            android:textColor="#78909C"
            android:layout_marginTop="12dp" />

        <!-- 鼓励语 -->
        <TextView
            android:id="@+id/tv_motivation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="记得多喝水，保持健康！"
            android:textSize="15sp"
            android:textColor="#90A4AE"
            android:layout_marginTop="24dp" />

        <!-- 自定义杯子按钮 -->
        <Button
            android:id="@+id/btn_custom_cup"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="+300ml"
            android:textSize="14sp"
            android:backgroundTint="#FF7043"
            android:layout_marginTop="16dp" />
    </LinearLayout>

</FrameLayout>
