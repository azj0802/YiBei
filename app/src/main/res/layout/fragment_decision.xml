<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="决策天平"
            android:textSize="22sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <!-- 选项A -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="选项 A"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_option_a"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 选项B -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="选项 B"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_option_b"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 评估维度 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="评估维度"
                android:textSize="16sp"
                android:textColor="#333333"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_new_dimension"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:hint="新维度"
                android:paddingStart="12dp"
                android:background="@drawable/edit_bg"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_add_dimension"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="添加"
                android:textSize="13sp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#607D8B" />
        </LinearLayout>

        <!-- 维度容器 -->
        <LinearLayout
            android:id="@+id/layout_dimensions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp" />

        <!-- 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn_weigh"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="2"
                android:text="开始权衡"
                android:textSize="16sp"
                android:backgroundTint="#2196F3"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btn_reset"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="重置"
                android:textSize="16sp"
                android:backgroundTint="#9E9E9E" />
        </LinearLayout>

        <!-- 结果区域 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="#333333"
                    android:visibility="gone"
                    android:gravity="center"
                    android:lineSpacingExtra="6dp" />

                <LinearLayout
                    android:id="@+id/layout_result_bar"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:id="@+id/tv_bar_a"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textSize="11sp"
                        android:textColor="#FFFFFF"
                        android:paddingStart="8dp"
                        android:paddingEnd="4dp"
                        android:background="#4CAF50" />

                    <View
                        android:id="@+id/view_bar_a"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="#4CAF50" />

                    <View
                        android:id="@+id/view_bar_b"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="#E0E0E0" />

                    <TextView
                        android:id="@+id/tv_bar_b"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textSize="11sp"
                        android:textColor="#333333"
                        android:paddingStart="4dp"
                        android:paddingEnd="8dp"
                        android:background="#E0E0E0" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
