<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ===== 顶部标题和日期选择 ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="健康监测"
                android:textSize="22sp"
                android:textColor="#333333"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/iv_date_left"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_previous"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="前一天" />

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026-07-07"
                android:textSize="15sp"
                android:textColor="#2196F3"
                android:textStyle="bold"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

            <ImageView
                android:id="@+id/iv_date_right"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_media_next"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="后一天" />
        </LinearLayout>

        <!-- ===== Health Connect 未授权引导 ===== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_permission_guide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_health"
                    android:alpha="0.4"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="需要授权 Health Connect"
                    android:textSize="16sp"
                    android:textColor="#333333"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="授权后可读取步数和睡眠数据"
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btn_request_permission"
                    android:layout_width="200dp"
                    android:layout_height="44dp"
                    android:text="前往授权"
                    android:textSize="14sp"
                    android:backgroundTint="#2196F3" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== 步数卡片 ===== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_steps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="今日步数"
                        android:textSize="15sp"
                        android:textColor="#666666" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/circle_indicator"
                        android:backgroundTint="#4CAF50" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Health Connect"
                        android:textSize="11sp"
                        android:textColor="#999999"
                        android:layout_marginStart="4dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_steps_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="48sp"
                    android:textColor="#333333"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="步"
                    android:textSize="18sp"
                    android:textColor="#999999"
                    android:layout_marginTop="-8dp" />

                <!-- 进度条 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp">

                    <ProgressBar
                        android:id="@+id/pb_steps"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="1"
                        android:max="100"
                        android:progressTint="#4CAF50"
                        android:progressBackgroundTint="#E0E0E0" />

                    <TextView
                        android:id="@+id/tv_steps_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:textColor="#4CAF50"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="目标 "
                        android:textSize="12sp"
                        android:textColor="#999999" />

                    <TextView
                        android:id="@+id/tv_steps_goal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8,000 步"
                        android:textSize="12sp"
                        android:textColor="#666666" />

                    <ImageView
                        android:id="@+id/iv_steps_goal_edit"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:contentDescription="修改目标"
                        android:layout_marginStart="4dp"
                        android:padding="2dp"
                        android:alpha="0.4" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tv_calories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="约 -- kcal"
                        android:textSize="12sp"
                        android:textColor="#999999" />
                </LinearLayout>

                <!-- 7天趋势图占位 -->
                <TextView
                    android:id="@+id/tv_trend_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="近7天步数趋势"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp" />

                <com.example.yibei.ui.StepTrendView
                    android:id="@+id/view_step_trend"
                    android:layout_width="match_parent"
                    android:layout_height="140dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== 睡眠卡片 ===== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_sleep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="昨晚睡眠"
                        android:textSize="15sp"
                        android:textColor="#666666" />

                    <ImageView
                        android:id="@+id/iv_sleep_edit"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_edit"
                        android:contentDescription="手动修改"
                        android:layout_marginEnd="8dp"
                        android:padding="2dp"
                        android:alpha="0.5" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/circle_indicator"
                        android:backgroundTint="#42A5F5" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Health Connect"
                        android:textSize="11sp"
                        android:textColor="#999999"
                        android:layout_marginStart="4dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_sleep_source"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sleep_inferred"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="true">

                    <TextView
                        android:id="@+id/tv_sleep_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="40sp"
                        android:textColor="#333333"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_sleep_score"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/score_badge_bg"
                        android:backgroundTint="#42A5F5"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:layout_marginStart="12dp"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="入睡 "
                            android:textSize="12sp"
                            android:textColor="#999999" />

                        <TextView
                            android:id="@+id/tv_sleep_start"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="12sp"
                            android:textColor="#666666" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="醒来 "
                            android:textSize="12sp"
                            android:textColor="#999999" />

                        <TextView
                            android:id="@+id/tv_sleep_end"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="12sp"
                            android:textColor="#666666" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 睡眠分期条 -->
                <com.example.yibei.ui.SleepStageView
                    android:id="@+id/view_sleep_stages"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="14dp" />

                <!-- 近七天睡眠趋势 -->
                <com.example.yibei.ui.SleepTrendView
                    android:id="@+id/view_sleep_trend"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== AI 分析卡片 ===== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_ai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="AI 健康分析"
                        android:textSize="15sp"
                        android:textColor="#666666" />

                    <Button
                        android:id="@+id/btn_ai_refresh"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="刷新"
                        android:textSize="13sp"
                        android:backgroundTint="#2196F3"
                        android:minWidth="0dp"
                        android:paddingHorizontal="16dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pb_ai_loading"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_ai_analysis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text='点击“刷新”获取 AI 健康分析建议'
                    android:textSize="13sp"
                    android:textColor="#999999"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
