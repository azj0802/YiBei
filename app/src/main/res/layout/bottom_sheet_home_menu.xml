<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:fillViewport="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ═══════ 智能饮水计算 ═══════ -->
        <LinearLayout
            android:id="@+id/layout_smart_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="智能饮水计算"
                android:textSize="16sp"
                android:textColor="#333333"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_smart_toggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="收起 ▲"
                android:textSize="13sp"
                android:textColor="#999999"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_smart_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp">

            <!-- 性别 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="性别"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:id="@+id/layout_gender"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <TextView
                    android:id="@+id/btn_male"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="男"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/tab_active_bg" />

                <TextView
                    android:id="@+id/btn_female"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="女"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:gravity="center"
                    android:background="@drawable/tab_inactive_bg" />
            </LinearLayout>

            <!-- 年龄 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="年龄"
                    android:textSize="13sp"
                    android:textColor="#666666" />

                <SeekBar
                    android:id="@+id/seek_age"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="79"
                    android:progress="29"
                    android:progressTint="#4A90D9"
                    android:thumbTint="#4A90D9" />

                <TextView
                    android:id="@+id/tv_age"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="30岁"
                    android:textSize="14sp"
                    android:textColor="#1A6BC4"
                    android:textStyle="bold"
                    android:gravity="end" />
            </LinearLayout>

            <!-- 体重 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="体重"
                    android:textSize="13sp"
                    android:textColor="#666666" />

                <SeekBar
                    android:id="@+id/seek_weight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="160"
                    android:progress="56"
                    android:progressTint="#4A90D9"
                    android:thumbTint="#4A90D9" />

                <TextView
                    android:id="@+id/tv_weight"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="68kg"
                    android:textSize="14sp"
                    android:textColor="#1A6BC4"
                    android:textStyle="bold"
                    android:gravity="end" />
            </LinearLayout>

            <!-- 身高 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="身高"
                    android:textSize="13sp"
                    android:textColor="#666666" />

                <SeekBar
                    android:id="@+id/seek_height"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="60"
                    android:progress="30"
                    android:progressTint="#4A90D9"
                    android:thumbTint="#4A90D9" />

                <TextView
                    android:id="@+id/tv_height"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="170cm"
                    android:textSize="14sp"
                    android:textColor="#1A6BC4"
                    android:textStyle="bold"
                    android:gravity="end" />
            </LinearLayout>

            <!-- 工作类型 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="工作 / 活动类型"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinner_work"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/edit_bg"
                android:paddingStart="12dp" />

            <!-- 城市 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="所在城市"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/et_city"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:hint="例如：北京"
                    android:paddingStart="12dp"
                    android:text="北京"
                    android:background="@drawable/edit_bg"
                    android:layout_marginEnd="10dp"
                    android:maxWidth="180dp" />

                <Button
                    android:id="@+id/btn_location"
                    android:layout_width="64dp"
                    android:layout_height="44dp"
                    android:text="定位"
                    android:textSize="14sp"
                    android:backgroundTint="#607D8B"
                    android:layout_marginEnd="6dp"
                    android:singleLine="true" />

                <Button
                    android:id="@+id/btn_weather"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:text="获取天气"
                    android:textSize="13sp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:backgroundTint="#4A90D9"
                    android:singleLine="true" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_weather_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="默认: 25℃ / 湿度60%"
                android:textSize="12sp"
                android:textColor="#999999"
                android:layout_marginBottom="14dp" />

            <!-- 饮食习惯 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="饮食习惯"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinner_diet"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/edit_bg"
                android:paddingStart="12dp" />

            <!-- 健康状况 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="健康状况"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:id="@+id/layout_health"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:layout_marginBottom="18dp">

                <TextView
                    android:id="@+id/btn_healthy"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="无基础病"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/tab_active_bg" />

                <TextView
                    android:id="@+id/btn_chronic"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="有基础病（肾病/心衰）"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:gravity="center"
                    android:background="@drawable/tab_inactive_bg" />
            </LinearLayout>

            <!-- 计算按钮 -->
            <Button
                android:id="@+id/btn_calc"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="AI 精准计算"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#1A6BC4"
                android:layout_marginBottom="16dp" />

            <!-- 结果卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tv_result_ml"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textSize="36sp"
                            android:textColor="#1A6BC4"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" ml / 日"
                            android:textSize="16sp"
                            android:textColor="#4A7A9C"
                            android:layout_marginStart="4dp" />

                        <TextView
                            android:id="@+id/tv_result_cups"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text=""
                            android:textSize="14sp"
                            android:textColor="#999999"
                            android:gravity="end" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layout_detail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#F8FBFF"
                        android:padding="12dp"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/tv_advice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="13sp"
                        android:textColor="#333333"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_ai_badge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="由 🐳 DeepSeek 生成"
                        android:textSize="11sp"
                        android:textColor="#8AB4D6"
                        android:gravity="end"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- ═══════ 每日目标 ═══════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="每日目标"
            android:textSize="16sp"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/et_goal"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="目标水量（ml）"
                android:inputType="number"
                android:paddingStart="16dp"
                android:background="@drawable/edit_bg"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btn_set_goal"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="设置"
                android:backgroundTint="#9C27B0" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#ECECEC" android:layout_marginBottom="20dp" />

        <!-- ═══════ 自定义水杯容量 ═══════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="自定义水杯容量"
            android:textSize="13sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <EditText
                android:id="@+id/et_cup_amount"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="杯子毫升数"
                android:inputType="number"
                android:paddingStart="16dp"
                android:background="@drawable/edit_bg"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btn_set_cup"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="设置容量"
                android:backgroundTint="#FF7043" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#ECECEC" android:layout_marginBottom="20dp" />

        <!-- ═══════ 快速记录 ═══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="快速记录"
                android:textSize="16sp"
                android:textColor="#333333"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_quick_record_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <Button
                android:id="@+id/btn_add_200"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="+200ml\n（一次性纸杯）"
                android:textSize="13sp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:backgroundTint="#2196F3" />

            <Button
                android:id="@+id/btn_add_300"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="+300ml\n（一罐可乐）"
                android:textSize="13sp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:backgroundTint="#4CAF50" />

            <Button
                android:id="@+id/btn_add_500"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="+500ml\n（一支矿泉水）"
                android:textSize="13sp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:backgroundTint="#FF9800" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/et_custom_amount"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="自定义水量（ml）"
                android:inputType="number"
                android:paddingStart="16dp"
                android:background="@drawable/edit_bg"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btn_custom_amount"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="记录"
                android:backgroundTint="#607D8B" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#ECECEC" android:layout_marginBottom="14dp" />

        <!-- 喝水记录 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="喝水记录"
            android:textSize="13sp"
            android:textColor="#666666"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_drink_history"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="暂无记录"
            android:textSize="13sp"
            android:textColor="#999999"
            android:lineSpacingExtra="4dp"
            android:padding="8dp"
            android:background="#F5F5F5" />

        </LinearLayout>
        <!-- ═══════ 快速记录 结束 ═══════ -->

    </LinearLayout>
</ScrollView>
